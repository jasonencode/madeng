<Window x:Class="MaDeng.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于 MaDeng"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#5B5BA0"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="24,7"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6E6EB8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#484888"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#F01E1E2E" BorderBrush="#313244" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="4" Color="#000000" Opacity="0.4"/>
        </Border.Effect>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="MaDeng" FontSize="20" FontWeight="Bold" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                <TextBlock Text="码灯 / 牛马指示灯" FontSize="12" Foreground="#888" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="#A0A0B0" FontSize="12" Margin="0,0,0,16">
                屏幕顶部状态指示灯，配合 Claude Code 使用。监控 Claude Code 会话状态，以三色灯显示工作状态。
            </TextBlock>

            <StackPanel Grid.Row="2" Margin="0,0,0,16">
                <TextBlock Text="状态说明" Foreground="#8888FF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Margin="10,0,0,0">
                    <TextBlock Foreground="#A0A0B0" FontSize="12" Margin="0,2"><Run Foreground="#22C55E">●</Run> Ready (idle) - 绿灯常亮，等待输入</TextBlock>
                    <TextBlock Foreground="#A0A0B0" FontSize="12" Margin="0,2"><Run Foreground="#FACC15">●</Run> Working - 跑马灯呼吸，工作中</TextBlock>
                    <TextBlock Foreground="#A0A0B0" FontSize="12" Margin="0,2"><Run Foreground="#22C55E">●</Run> Done (completed) - 绿灯呼吸，任务完成</TextBlock>
                    <TextBlock Foreground="#A0A0B0" FontSize="12" Margin="0,2"><Run Foreground="#FACC15">●</Run> Waiting - 三灯闪烁，等待授权</TextBlock>
                    <TextBlock Foreground="#A0A0B0" FontSize="12" Margin="0,2"><Run Foreground="#EF4444">●</Run> Error - 红灯呼吸，出现错误</TextBlock>
                </StackPanel>
            </StackPanel>

            <Button Grid.Row="3" Content="关闭" Click="Close_Click" Width="80" Height="32" HorizontalAlignment="Center"
                    Style="{StaticResource CloseButtonStyle}"/>
        </Grid>
    </Border>
</Window>
