<Window x:Class="MaDeng.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MaDeng"
    Title="MaDeng"
    Width="360"
    WindowStyle="None" AllowsTransparency="True"
    Background="Transparent" Topmost="True"
    ShowInTaskbar="False" ResizeMode="NoResize"
    SizeToContent="Height"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    Loaded="Window_Loaded">

    <Window.Resources>
        <!-- 右键菜单样式 -->
        <Style x:Key="TrayMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="BorderBrush" Value="#3A3A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="4" Color="#000000" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#3A3A55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#3A3A50"/>
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="8,4"/>
        </Style>

        <ContextMenu x:Key="TrayMenu" Style="{StaticResource TrayMenuStyle}">
            <MenuItem Header="设置" Click="Settings_Click" Style="{StaticResource MenuItemStyle}"/>
            <Separator Style="{StaticResource SeparatorStyle}"/>
            <MenuItem Header="还原位置" Click="ResetPosition_Click" Style="{StaticResource MenuItemStyle}"/>
            <Separator Style="{StaticResource SeparatorStyle}"/>
            <MenuItem Header="关于" Click="About_Click" Style="{StaticResource MenuItemStyle}"/>
            <MenuItem Header="退出" Click="Exit_Click" Style="{StaticResource MenuItemStyle}"/>
        </ContextMenu>

        <!-- Session 行模板 -->
        <DataTemplate x:Key="SessionTemplate">
            <DockPanel Margin="0,2,0,5" LastChildFill="False">

                <!-- Agent 名字 -->
                <TextBlock Text="{Binding AgentName}" Foreground="#8888FF" FontSize="11"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" Width="50" TextAlignment="Right" Margin="0,0,6,0" />
                <!-- 状态文字 - 固定宽度 -->
                <TextBlock Text="{Binding Pid}" Foreground="#E0E0E0" FontSize="11"
                    VerticalAlignment="Center" Width="50" TextAlignment="Left" Margin="6,0,0,0" />
                <!-- 红绿灯 - 固定宽度 -->
                <StackPanel Orientation="Horizontal" Width="60" VerticalAlignment="Center">
                    <local:StatusLamp LampIndex="0" Status="{Binding Status}" Width="16" Height="16"
                        Margin="2,0" />
                    <local:StatusLamp LampIndex="1" Status="{Binding Status}" Width="16" Height="16"
                        Margin="2,0" />
                    <local:StatusLamp LampIndex="2" Status="{Binding Status}" Width="16" Height="16"
                        Margin="2,0" />
                </StackPanel>
                <!-- 状态文字 - 固定宽度 -->
                <TextBlock Text="{Binding StatusText}" Foreground="#E0E0E0" FontSize="11"
                    VerticalAlignment="Center" Width="60" TextAlignment="Left" Margin="6,0,0,0" />
                <!-- 打开目录按钮 - 右侧对齐 -->
                <Button DockPanel.Dock="Right" Click="OpenCwd_Click" Cursor="Hand"
                    Background="Transparent" BorderThickness="0" Padding="4,2"
                    ToolTip="{Binding Cwd}" VerticalAlignment="Center" Margin="4,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Path
                        Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2,0,0,0,4,20H20A2,2,0,0,0,22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                        Fill="#808090" Width="12" Height="12" Stretch="Uniform" />
                </Button>
            </DockPanel>
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="MainBorder" CornerRadius="0,0,14,14" Background="#991E1E2E" Padding="10"
        ContextMenu="{StaticResource TrayMenu}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="8" Opacity="0.3" ShadowDepth="2" />
        </Border.Effect>
        <DockPanel>
            <Image Source="/MaDeng;component/logo.png" Width="32" Height="32" DockPanel.Dock="Left"
                VerticalAlignment="Center" Margin="0,0,8,0" />
            <ItemsControl x:Name="SessionsList" ItemTemplate="{StaticResource SessionTemplate}"
                VerticalAlignment="Center" HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </DockPanel>
    </Border>
</Window>