<Window x:Class="MaDeng.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MaDeng" Width="260"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <ContextMenu x:Key="TrayMenu">
            <MenuItem Header="设置" Click="Settings_Click"/>
            <Separator/>
            <MenuItem Header="恢复Ready状态" Click="ResetStatus_Click"/>
            <MenuItem Header="还原位置" Click="ResetPosition_Click"/>
            <Separator/>
            <MenuItem Header="关于" Click="About_Click"/>
            <MenuItem Header="退出" Click="Exit_Click"/>
        </ContextMenu>

        <!-- 单个 session 灯的模板 -->
        <DataTemplate x:Key="SessionLightTemplate">
            <Border CornerRadius="0,0,10,10" Background="#1E1E2E" Opacity="0.6" Margin="0,0,0,2"
                    ContextMenu="{StaticResource TrayMenu}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" Opacity="0.3" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8,4">
                    <!-- PID -->
                    <TextBlock Text="{Binding Pid}" Foreground="#A0A0B0" FontSize="11"
                               VerticalAlignment="Center" Width="40" TextAlignment="Right" Margin="0,0,6,0"/>
                    <!-- 绿灯 -->
                    <Ellipse Width="16" Height="16" Margin="4,0">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="GreenGlow" Color="#16A34A" BlurRadius="0" Opacity="0"/>
                        </Ellipse.Effect>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop x:Name="GreenInner" Color="#1A1A2E" Offset="0"/>
                                <GradientStop x:Name="GreenOuter" Color="#1A1A2E" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- 黄灯 -->
                    <Ellipse Width="16" Height="16" Margin="4,0">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="YellowGlow" Color="#EAB308" BlurRadius="0" Opacity="0"/>
                        </Ellipse.Effect>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop x:Name="YellowInner" Color="#1A1A2E" Offset="0"/>
                                <GradientStop x:Name="YellowOuter" Color="#1A1A2E" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- 红灯 -->
                    <Ellipse Width="16" Height="16" Margin="4,0">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="RedGlow" Color="#DC2626" BlurRadius="0" Opacity="0"/>
                        </Ellipse.Effect>
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop x:Name="RedInner" Color="#1A1A2E" Offset="0"/>
                                <GradientStop x:Name="RedOuter" Color="#1A1A2E" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <!-- 状态文本 -->
                    <TextBlock Text="{Binding StatusText}" Foreground="#E0E0E0" FontSize="11"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <ItemsControl x:Name="SessionsList" ItemTemplate="{StaticResource SessionLightTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</Window>
